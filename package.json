{
  "name": "forge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "pretypecheck": "if [ -f packages/shared/package.json ]; then npm run build --workspace=packages/shared; fi",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "pretest": "if [ -f packages/shared/package.json ]; then npm run build --workspace=packages/shared; fi",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "npm run pretest && vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "bruno": "cd bruno && npx @usebruno/cli run -r --env local",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FundamentalMedia/forge.git"
  },
  "bugs": {
    "url": "https://github.com/FundamentalMedia/forge/issues"
  },
  "homepage": "https://github.com/FundamentalMedia/forge#readme",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  }
}
