meta {
  name: My Tag Subscriptions
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/api/tags/subscriptions
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 200
}

docs {
  Returns the authenticated user's subscribed tags.
  Response: { tags: Tag[] }
}
