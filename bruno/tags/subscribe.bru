meta {
  name: Subscribe to Tag
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/tags/{{tagId}}/subscribe
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 201
}

docs {
  Subscribe to a tag. Idempotent — returns 201 on new subscription, 200 if already subscribed.
  Requires {{tagId}} — get from List Tags or Popular Tags.
  Response: { subscribed: true, alreadySubscribed: boolean }
}
