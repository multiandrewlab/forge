meta {
  name: Delete Post
  type: http
  seq: 6
}

delete {
  url: {{baseUrl}}/api/posts/{{createdPostId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 204
}

docs {
  Soft-deletes the post (sets deletedAt timestamp).
  Only the post author can delete.
}
